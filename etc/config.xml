<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <mercure>
            <general>
                <enabled>0</enabled>
                <hub_url>http://localhost:8080/.well-known/mercure</hub_url>
            </general>
            <jwt_publisher>
                <jwt_algorithm>hmac.sha256</jwt_algorithm>
                <jwt_ttl>3600</jwt_ttl>
            </jwt_publisher>
            <jwt_subscriber>
                <jwt_algorithm>hmac.sha256</jwt_algorithm>
                <jwt_ttl>3600</jwt_ttl>
            </jwt_subscriber>
        </mercure>
    </default>
</config>
